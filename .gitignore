# =====================
# Secrets / local config
# =====================
.env
.env.*

# main config file (do NOT commit real credentials)
api.yaml
api.yml
formatted.yaml

# local config variants
api.json
api.*.json

# runtime data / volumes
data/
postgres_data/

# =====================
# Python
# =====================
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg-info/

.venv/
venv/
ENV/

.pytest_cache/
.mypy_cache/
.ruff_cache/

.coverage
coverage/
htmlcov/

# =====================
# Node / Frontend
# =====================
**/node_modules/
**/dist/
**/.vite/
**/.cache/

npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Frontend build output served by backend (generated by `frontend` build)
# If you deploy via Dockerfile (multi-stage build), static is generated during image build.
# Do NOT commit built files.
static/

# =====================
# Databases
# =====================
*.db
*.db-wal
*.db-shm

# =====================
# IDE / OS
# =====================
.vscode/
.idea/
.DS_Store
Thumbs.db

# =====================
# Tools / Misc
# =====================
.wrangler/
.aider*

# git worktree directories (local)
.worktrees/

docker-compose-*.yml
plugins/secret_plugins/

# (If you use alembic locally and don't want it in repo)
# alembic/
# alembic.ini

.limcode/
test/
# 修改原因：根级 test/ 忽略规则会覆盖 frontend/test，导致前端回归测试文件默认无法进入版本控制。
# 修改方式：只对 frontend/test 目录追加例外，不改变根目录运行时 test 数据的忽略行为。
# 目的：让前端轻量回归测试可以随源码一起保存，避免移动端抽屉布局问题回退。
!frontend/test/
!frontend/test/**frontend/test/
.limcode/
tests/
